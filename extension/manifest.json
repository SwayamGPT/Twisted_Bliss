{
  "manifest_version": 3,
  "name": "Twisted Bliss IG Importer",
  "version": "1.0",
  "description": "Easily export Instagram DMs to the Twisted Bliss Dashboard",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:3001/*",
    "http://127.0.0.1:3001/*",
    "https://*.instagram.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Twisted Bliss Importer"
  }
}
